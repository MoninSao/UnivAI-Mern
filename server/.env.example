# MongoDB Atlas connection string
# Get this from: MongoDB Atlas dashboard → your cluster → Connect → Drivers
ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# Port the Express server listens on
# Render sets this automatically in production — keep 5050 for local dev
PORT=5050

# API key for the College Scorecard API
# Get this from: https://collegescorecard.ed.gov/data/documentation/
COLLEGE_SCORECARD_API_KEY=your_key_here

# API key for OpenAI
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# URL of the frontend — used to restrict CORS
# Local dev: http://localhost:5173
# Production: set this in Render dashboard to your Vercel frontend URL
CLIENT_URL=http://localhost:5173
